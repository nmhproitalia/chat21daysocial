rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Users can upload and read their own files
    match /post-media/{fileName} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Allow read access to all files
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
