rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow read/write to authenticated users
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
    
    // Allow access to subcollections
    match /posts/{postId}/{subcollection=**} {
      allow read, write: if request.auth != null;
    }
  }
}
